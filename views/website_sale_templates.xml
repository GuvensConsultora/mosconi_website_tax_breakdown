<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!--
        Template 1: Desglose de impuestos en tarjeta de tienda (/shop)

        Por qué: El precio mostrado en Odoo incluye IVA por defecto sin detallarlo.
        Mostramos el precio sin impuestos + cada impuesto por separado.

        Patrón: Template inheritance con xpath position="inside" sobre el div de precio.
        Tip: products_item es el template de la tarjeta en la grilla de la tienda.
    -->
    <template
        id="product_item_price_tax_breakdown"
        inherit_id="website_sale.products_item"
    >
        <xpath expr="//div[contains(@class,'product_price')]" position="inside">

            <t t-set="tax_data" t-value="product.get_website_tax_breakdown()"/>

            <!--
                Por qué small text-muted: Info secundaria, no compite con el precio principal.
                Solo se muestra si hay datos y currency válida (evita errores en render).
            -->
            <t t-if="tax_data and tax_data.get('currency')">
                <div class="small text-muted mt-1">

                    <div>
                        Precio sin imp.:
                        <strong
                            t-out="tax_data['price_excluded']"
                            t-options="{'widget': 'monetary', 'display_currency': tax_data['currency']}"
                        />
                    </div>

                    <!--
                        Por qué total en lugar de iterar por nombre:
                        Evita nombres técnicos (VAT, IVA, etc.) en la tarjeta.
                    -->
                    <div>
                        Impuestos:
                        <span
                            t-out="tax_data['price_included'] - tax_data['price_excluded']"
                            t-options="{'widget': 'monetary', 'display_currency': tax_data['currency']}"
                        />
                    </div>

                </div>

                <!--
                    Badge de descuento dentro del mismo xpath para no depender
                    de name="product_base_price" que puede no existir en todas
                    las versiones. template_price_vals ya está disponible en
                    el contexto del template products_item.

                    Cálculo: (base_price - price_reduce) / base_price * 100
                -->
                <t t-if="'base_price' in template_price_vals
                         and template_price_vals.get('base_price', 0) > template_price_vals.get('price_reduce', 0)
                         and template_price_vals.get('price_reduce')">
                    <span class="badge bg-danger mt-1">
                        <t t-esc="'-' + str(round(
                            (template_price_vals['base_price'] - template_price_vals['price_reduce'])
                            / template_price_vals['base_price'] * 100
                        )) + '%'"/>
                    </span>
                </t>

            </t>

        </xpath>

    </template>

    <!--
        Template 2: Desglose de impuestos en ficha de producto

        Por qué inherit_id="website_sale.product_price": El bloque de precio
        de la ficha vive en este sub-template, no en website_sale.product.

        Por qué NO mostrar "Total": El precio principal (oe_price) ya es el
        precio con impuestos incluidos. Repetirlo como "Total" es redundante
        y confunde al usuario.
    -->
    <template
        id="product_page_price_tax_breakdown"
        inherit_id="website_sale.product_price"
    >
        <!--
            Por qué css_editable_mode_hidden: Este div ya existe en el template
            padre con esa clase, insertamos después para mantener el orden visual.
        -->
        <xpath expr="//div[@name='product_price_container']" position="after">

            <t t-set="tax_data" t-value="product.get_website_tax_breakdown()"/>

            <t t-if="tax_data and tax_data.get('currency')">
                <div class="small text-muted mt-2">

                    <div>
                        Precio sin imp.:
                        <strong
                            t-out="tax_data['price_excluded']"
                            t-options="{'widget': 'monetary', 'display_currency': tax_data['currency']}"
                        />
                    </div>

                    <!--
                        Por qué total genérico y no iterar por nombre:
                        Evita mostrar nombres técnicos (VAT, IVA, etc.).
                        El total de impuestos = price_included - price_excluded.
                    -->
                    <div>
                        Impuestos:
                        <span
                            t-out="tax_data['price_included'] - tax_data['price_excluded']"
                            t-options="{'widget': 'monetary', 'display_currency': tax_data['currency']}"
                        />
                    </div>

                </div>
            </t>

        </xpath>

        <!--
            Porcentaje de descuento en ficha de producto.

            Por qué sobre product_list_price: Es el span del precio tachado
            (list_price cuando has_discounted_price=True).

            combination_info['list_price'] = precio original (tachado)
            combination_info['price']      = precio actual con descuento
        -->
        <xpath expr="//span[@name='product_list_price']" position="after">
            <t t-if="combination_info.get('has_discounted_price')
                     and combination_info.get('list_price', 0) > 0
                     and combination_info.get('price', 0) > 0">
                <span class="badge bg-danger ms-1 align-self-center">
                    <t t-esc="'-' + str(round(
                        (combination_info['list_price'] - combination_info['price'])
                        / combination_info['list_price'] * 100
                    )) + '%'"/>
                </span>
            </t>
        </xpath>

    </template>

</odoo>
